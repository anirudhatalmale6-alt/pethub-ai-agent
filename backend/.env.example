# PetHub AI Agent - Backend Environment Variables
# Copy this to .env and fill in your values

# App
ENVIRONMENT=development
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://pethub:pethub@db:5432/pethub_agent

# Redis
REDIS_URL=redis://redis:6379/0

# OpenAI - GET YOUR OWN KEY AT https://platform.openai.com
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# JWT Auth - CHANGE THIS IN PRODUCTION
JWT_SECRET=change-this-to-a-random-secure-string
JWT_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=["http://localhost:3000"]
